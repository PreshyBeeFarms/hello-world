    <!-- ===== JAVASCRIPT ===== -->
    <script>
        // ============================================================
        // ===== SLIDESHOW =====
        // ============================================================
        var landingSlides = document.getElementById('landingSlides');
        var landingDots = document.querySelectorAll('.landing-dot');
        var currentLanding = 0;
        var totalLanding = 6;
        var landingInterval;

        function updateLanding(index) {
            landingSlides.style.transform = 'translateX(-' + (index * 100) + '%)';
            landingDots.forEach(function(dot, i) {
                dot.classList.toggle('active', i === index);
            });
            currentLanding = index;
        }

        function landingNext() {
            updateLanding((currentLanding + 1) % totalLanding);
            resetLandingTimer();
        }

        function landingPrev() {
            updateLanding((currentLanding - 1 + totalLanding) % totalLanding);
            resetLandingTimer();
        }

        function resetLandingTimer() {
            clearInterval(landingInterval);
            landingInterval = setInterval(landingNext, 6000);
        }

        landingDots.forEach(function(dot) {
            dot.addEventListener('click', function() {
                updateLanding(parseInt(this.getAttribute('data-index')));
                resetLandingTimer();
            });
        });

        landingInterval = setInterval(landingNext, 6000);

        // ============================================================
        // ===== PAGE NAVIGATION =====
        // ============================================================
        function showPage(pageName) {
            document.querySelectorAll('.page').forEach(function(p) {
                p.classList.remove('active');
            });
            var target = document.getElementById('page-' + pageName);
            if (target) target.classList.add('active');

            document.querySelectorAll('.nav-links a').forEach(function(a) {
                a.classList.remove('active');
            });
            var navLink = document.getElementById('nav-' + pageName);
            if (navLink) navLink.classList.add('active');

            if (pageName === 'products') backToProducts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ============================================================
        // ===== PRODUCT DETAIL =====
        // ============================================================
        function showProductDetail(productId) {
            var grid = document.getElementById('productGrid');
            if (grid) grid.style.display = 'none';

            document.querySelectorAll('.product-detail').forEach(function(d) {
                d.classList.remove('active');
            });
            var detail = document.getElementById('detail-' + productId);
            if (detail) detail.classList.add('active');

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function backToProducts() {
            var grid = document.getElementById('productGrid');
            if (grid) grid.style.display = 'block';

            document.querySelectorAll('.product-detail').forEach(function(d) {
                d.classList.remove('active');
            });
        }

        // ============================================================
        // ===== SEARCH =====
        // ============================================================
        var searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                var term = this.value.toLowerCase();
                var cards = document.querySelectorAll('.product-card');
                cards.forEach(function(card) {
                    var name = card.getAttribute('data-name') || '';
                    card.style.display = name.toLowerCase().includes(term) ? '' : 'none';
                });
            });
        }

        // ============================================================
        // ===== CART =====
        // ============================================================
        var cart = [];

        function addToCart(item) {
            cart.push(item);
            updateCartCount();
            showNotification(item + ' added to cart! 🛒');
            saveCart();
        }

        function updateCartCount() {
            var countEl = document.getElementById('cartCount');
            if (countEl) countEl.textContent = cart.length;
        }

        function showNotification(msg) {
            var div = document.createElement('div');
            div.className = 'notification';
            div.textContent = msg;
            document.body.appendChild(div);
            setTimeout(function() { div.remove(); }, 3000);
        }

        function showCartPopup() {
            if (cart.length === 0) {
                showNotification('Your cart is empty 🛒');
                return;
            }

            var existing = document.getElementById('cartPopup');
            if (existing) existing.remove();

            var popup = document.createElement('div');
            popup.id = 'cartPopup';
            popup.className = 'cart-popup';

            var itemsHtml = '';
            cart.forEach(function(item, index) {
                itemsHtml += '<div class="cart-item"><span>' + item + '</span><span class="remove" onclick="removeFromCart(' +
                    index + ')">✕</span></div>';
            });

            popup.innerHTML = `
                <h3>Your Cart 🛒</h3>
                <div style="max-height:300px; overflow-y:auto;">${itemsHtml}</div>
                <div class="cart-actions">
                    <button class="clear" onclick="clearCart()">Clear All</button>
                    <button class="checkout" onclick="checkout()">Checkout</button>
                    <button class="close" onclick="closeCartPopup()">Close</button>
                </div>
                <div class="total">Total items: ${cart.length}</div>
            `;

            document.body.appendChild(popup);
        }

        function closeCartPopup() {
            var popup = document.getElementById('cartPopup');
            if (popup) popup.remove();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCartCount();
            saveCart();
            showCartPopup();
        }

        function clearCart() {
            cart = [];
            updateCartCount();
            saveCart();
            closeCartPopup();
            showNotification('Cart cleared 🗑️');
        }

        function checkout() {
            closeCartPopup();
            var items = cart.join(', ');
            var msg = 'Hello PreshyBee Farms! I\'d like to order: ' + items + '. Please provide pricing and delivery options.';
            window.location.href = 'https://wa.me/2348073938083?text=' + encodeURIComponent(msg);
        }

        function saveCart() {
            localStorage.setItem('preshybeecart', JSON.stringify(cart));
        }

        function loadCart() {
            var saved = localStorage.getItem('preshybeecart');
            if (saved) {
                cart = JSON.parse(saved);
                updateCartCount();
            }
        }

        loadCart();

        // ============================================================
        // ===== MOBILE MENU =====
        // ============================================================
        var hamburgerBtn = document.getElementById('hamburgerBtn');
        var navLinks = document.getElementById('navLinks');

        if (hamburgerBtn && navLinks) {
            hamburgerBtn.addEventListener('click', function() {
                navLinks.classList.toggle('open');
            });
        }

        // ============================================================
        // ===== FEEDBACK =====
        // ============================================================
        function submitFeedback() {
            var name = document.getElementById('fbName').value;
            var message = document.getElementById('fbMessage').value;

            if (!name || !message) {
                alert('Please fill in your name and review message.');
                return;
            }

            document.getElementById('feedbackForm').style.display = 'none';
            document.getElementById('feedbackSuccess').style.display = 'block';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>

