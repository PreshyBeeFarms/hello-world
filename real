<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PreshyBee Farms Group | Premium Agriculture</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #fafafa;
            color: #1a1a1a;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ===== TOP BAR ===== */
        .top-bar {
            background: #111;
            color: #ccc;
            font-size: 12px;
            padding: 8px 20px;
            text-align: center;
            letter-spacing: 0.5px;
        }
        .top-bar span {
            color: #d4af37;
            font-weight: 500;
        }

        /* ===== NAVIGATION ===== */
        nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid #e0e0e0;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }

        nav .logo {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 700;
            color: #111;
            cursor: pointer;
        }
        nav .logo span {
            font-weight: 400;
            color: #d4af37;
        }

        nav .nav-links {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            align-items: center;
        }

        nav .nav-links a {
            text-decoration: none;
            color: #555;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            cursor: pointer;
            transition: color 0.3s;
        }
        nav .nav-links a:hover,
        nav .nav-links a.active {
            color: #d4af37;
        }

        nav .cta-nav {
            background: #d4af37;
            color: #111;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .hamburger {
            display: none;
            background: none;
            border: none;
            font-size: 28px;
            cursor: pointer;
            color: #111;
            padding: 4px 8px;
        }

        /* ===== PAGES ===== */
        .page {
            display: none;
        }
        .page.active {
            display: block;
        }

        /* ===== SLIDESHOW ===== */
        .landing-slideshow {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
            background: #111;
        }

        .landing-slides {
            display: flex;
            width: 100%;
            height: 100%;
            transition: transform 1s cubic-bezier(0.65, 0, 0.35, 1);
        }

        .landing-slide {
            min-width: 100%;
            height: 100%;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background-size: cover;
            background-position: center;
        }

        .landing-slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.8) 100%);
            z-index: 1;
        }

        .landing-slide-1 {
            background-image: url('https://images.pexels.com/photos/162636/chickens-poultry-free-range-162636.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }
        .landing-slide-2 {
            background-image: url('https://images.pexels.com/photos/6937747/pexels-photo-6937747.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }
        .landing-slide-3 {
            background-image: url('https://images.pexels.com/photos/2132171/pexels-photo-2132171.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }
        .landing-slide-4 {
            background-image: url('https://images.pexels.com/photos/14463139/pexels-photo-14463139.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }
        .landing-slide-5 {
            background-image: url('https://images.pexels.com/photos/2252584/pexels-photo-2252584.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }
        .landing-slide-6 {
            background-image: url('https://images.pexels.com/photos/14424886/pexels-photo-14424886.jpeg?auto=compress&cs=tinysrgb&w=1400');
        }

        .landing-slide-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: white;
            padding: 20px;
            max-width: 650px;
        }

        .landing-slide-content .tag {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .landing-slide-content h1 {
            font-family: 'Playfair Display', serif;
            font-size: 40px;
            font-weight: 500;
            letter-spacing: -1px;
            margin-bottom: 15px;
            line-height: 1.2;
            text-shadow: 0 2px 30px rgba(0, 0, 0, 0.6);
        }
        .landing-slide-content h1 strong {
            font-weight: 700;
        }

        .landing-slide-content p {
            font-size: 16px;
            font-weight: 300;
            color: #ddd;
            text-shadow: 0 1px 10px rgba(0, 0, 0, 0.5);
            margin-bottom: 25px;
        }

        .landing-slide-content .btn-gold {
            display: inline-block;
            background: #d4af37;
            color: #111;
            text-decoration: none;
            padding: 14px 32px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.3s;
        }

        .landing-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 10;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        .landing-arrow:hover {
            background: rgba(212, 175, 55, 0.4);
        }
        .landing-arrow.prev {
            left: 20px;
        }
        .landing-arrow.next {
            right: 20px;
        }

        .landing-dots {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            display: flex;
            gap: 10px;
        }

        .landing-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            border: none;
            cursor: pointer;
            transition: all 0.3s;
        }
        .landing-dot.active {
            background: #d4af37;
            transform: scale(1.3);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            color: white;
            text-align: center;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            animation: bounce 2s infinite;
        }
        .scroll-indicator span {
            display: block;
            font-size: 20px;
            margin-top: 5px;
        }

        @keyframes bounce {
            0%,
            100% {
                transform: translateX(-50%) translateY(0);
            }
            50% {
                transform: translateX(-50%) translateY(10px);
            }
        }

        /* ===== INNER PAGES ===== */
        .inner-page {
            padding-top: 20px;
        }

        .section-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 10px;
            text-align: center;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            font-weight: 500;
            text-align: center;
            color: #111;
            letter-spacing: -0.5px;
            margin-bottom: 10px;
        }

        .section-subtitle {
            text-align: center;
            color: #777;
            font-size: 14px;
            font-weight: 300;
            max-width: 500px;
            margin: 0 auto 40px;
            line-height: 1.7;
        }

        .divider {
            width: 40px;
            height: 1px;
            background: #d4af37;
            margin: 0 auto 35px;
        }

        .container {
            max-width: 950px;
            margin: 0 auto;
            padding: 50px 25px;
        }

        /* ===== SEARCH BAR ===== */
        .search-bar {
            text-align: center;
            margin: -10px 0 30px;
        }
        .search-bar input {
            padding: 12px 20px;
            border: 1px solid #ddd;
            border-radius: 30px;
            width: 100%;
            max-width: 350px;
            font-size: 14px;
            outline: none;
            transition: all 0.3s;
        }
        .search-bar input:focus {
            border-color: #d4af37;
        }

        /* ===== PRODUCT GRID ===== */
        .product-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
        }

        .product-card {
            background: white;
            border: 1px solid #eee;
            border-radius: 4px;
            padding: 25px 18px;
            text-align: center;
            width: 150px;
            flex-grow: 1;
            cursor: pointer;
            transition: all 0.3s;
        }
        .product-card:hover,
        .product-card:active {
            border-color: #d4af37;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            transform: translateY(-3px);
        }

        .product-card .p-emoji {
            font-size: 40px;
            margin-bottom: 10px;
        }
        .product-card h3 {
            font-family: 'Playfair Display', serif;
            font-size: 14px;
            font-weight: 600;
            color: #111;
            margin-bottom: 4px;
        }
        .product-card p {
            font-size: 11px;
            color: #999;
        }

        .product-card .add-btn {
            background: #d4af37;
            color: #111;
            border: none;
            padding: 8px 14px;
            border-radius: 30px;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 10px;
            transition: all 0.3s;
        }
        .product-card .add-btn:hover {
            background: #b8960f;
        }

        /* ===== PRODUCT DETAIL ===== */
        .product-detail {
            display: none;
            text-align: center;
        }
        .product-detail.active {
            display: block;
        }

        .product-detail .back-btn {
            display: inline-block;
            margin-bottom: 25px;
            color: #d4af37;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .product-detail .detail-image {
            width: 100%;
            max-width: 500px;
            height: 300px;
            object-fit: cover;
            border-radius: 4px;
            margin: 0 auto 25px;
            display: block;
            background: #eee;
        }
        .product-detail h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 600;
            color: #111;
            margin-bottom: 8px;
        }
        .product-detail .price {
            font-size: 18px;
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 15px;
        }
        .product-detail .description {
            font-size: 15px;
            color: #555;
            max-width: 500px;
            margin: 0 auto 25px;
            line-height: 1.8;
        }
        .product-detail .btn-order {
            display: inline-block;
            background: #d4af37;
            color: #111;
            text-decoration: none;
            padding: 14px 35px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* ===== FEEDBACK ===== */
        .feedback-form {
            background: white;
            border: 1px solid #eee;
            border-radius: 4px;
            padding: 30px 25px;
            max-width: 550px;
            margin: 0 auto 30px;
        }
        .feedback-form label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #111;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 6px;
            margin-top: 15px;
        }
        .feedback-form input,
        .feedback-form select,
        .feedback-form textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .feedback-form input:focus,
        .feedback-form textarea:focus {
            border-color: #d4af37;
            outline: none;
        }
        .feedback-form textarea {
            height: 100px;
            resize: vertical;
        }
        .feedback-form button {
            background: #d4af37;
            color: #111;
            border: none;
            padding: 14px 35px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 18px;
            width: 100%;
            transition: all 0.3s;
        }

        .feedback-success {
            display: none;
            text-align: center;
            padding: 20px;
            background: #e8f5e9;
            border-radius: 4px;
            color: #1b5e20;
            font-weight: 500;
            max-width: 550px;
            margin: 0 auto;
        }

        .reviews-list {
            max-width: 550px;
            margin: 30px auto 0;
        }
        .review-card {
            background: white;
            border: 1px solid #eee;
            border-radius: 4px;
            padding: 20px;
            margin-bottom: 15px;
        }
        .review-card .stars {
            color: #d4af37;
            font-size: 14px;
            margin-bottom: 6px;
        }
        .review-card .review-text {
            font-size: 14px;
            color: #555;
            font-style: italic;
            line-height: 1.7;
        }
        .review-card .review-author {
            font-size: 11px;
            font-weight: 600;
            color: #111;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 8px;
        }

        /* ===== FOOTER ===== */
        footer {
            background: #111;
            color: #777;
            padding: 50px 25px 25px;
            text-align: center;
        }
        footer .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: white;
            margin-bottom: 6px;
        }
        footer .footer-brand span {
            font-weight: 400;
            color: #d4af37;
        }
        footer .footer-links {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin: 20px 0;
            flex-wrap: wrap;
        }
        footer .footer-links a {
            color: #aaa;
            text-decoration: none;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: color 0.3s;
        }
        footer .footer-links a:hover {
            color: #d4af37;
        }
        footer .copyright {
            font-size: 10px;
            color: #555;
            margin-top: 20px;
        }

        /* ===== NOTIFICATION ===== */
        .notification {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #111;
            color: #d4af37;
            padding: 16px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            z-index: 9999;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
            animation: slideUp 0.4s ease;
        }
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== CART POPUP ===== */
        .cart-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            width: 90%;
            max-width: 400px;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            z-index: 9999;
        }
        .cart-popup h3 {
            font-family: 'Playfair Display', serif;
            margin-bottom: 15px;
        }
        .cart-popup .cart-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }
        .cart-popup .cart-item .remove {
            cursor: pointer;
            color: #d4af37;
        }
        .cart-popup .cart-actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        .cart-popup .cart-actions button {
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            flex: 1;
        }
        .cart-popup .cart-actions .clear {
            background: #f0f0f0;
            color: #111;
        }
        .cart-popup .cart-actions .checkout {
            background: #d4af37;
            color: #111;
        }
        .cart-popup .cart-actions .close {
            background: #111;
            color: white;
        }
        .cart-popup .total {
            text-align: center;
            margin-top: 12px;
            font-size: 12px;
            color: #999;
        }

        .cart-count {
            background: #d4af37;
            color: #111;
            border-radius: 50%;
            padding: 1px 8px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 4px;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 640px) {
            .hamburger {
                display: block;
            }
            .nav-links {
                display: none;
                width: 100%;
                flex-direction: column;
                align-items: center;
                gap: 10px;
                padding-top: 10px;
            }
            .nav-links.open {
                display: flex;
            }
            .landing-slide-content h1 {
                font-size: 28px;
            }
            .landing-slide-content p {
                font-size: 13px;
            }
            .landing-arrow {
                width: 35px;
                height: 35px;
                font-size: 14px;
            }
            nav .logo {
                font-size: 18px;
            }
        }
    </style>
</head>
